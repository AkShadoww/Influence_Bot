# Slack channel IDs for notifications
SLACK_TEAM_CHANNEL_ID=C0XXXXXXXXX
SLACK_ALERTS_CHANNEL_ID=C0XXXXXXXXX

# --- Email Configuration (jennifer@useinfluence.xyz) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=jennifer@useinfluence.xyz
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Jennifer - INFLUENCE

# --- Tally Configuration ---
TALLY_WEBHOOK_SECRET=your-tally-webhook-secret

# --- Instagram / Meta API ---
INSTAGRAM_ACCESS_TOKEN=your-instagram-graph-api-token

# --- Anthropic AI ---
